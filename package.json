{
  "name": "obsidian-mobile-pdf-exporter-kr",
  "version": "0.1.1",
  "description": "One-click selectable Korean preview PDF export plugin.",
  "main": "main.js",
  "scripts": {
    "build:font": "node scripts/build-korean-font.mjs",
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "release": "npm run build && node scripts/package-release.mjs",
    "typecheck": "tsc --noEmit",
    "test:licenses": "node scripts/test-license-notices.mjs",
    "test:korean-font": "node scripts/test-korean-font.mjs",
    "test:apple-pdfkit": "swift scripts/test-apple-pdfkit.swift dist/korean-selectable-smoke.pdf",
    "test:text-layout": "node scripts/test-text-layout.mjs",
    "test:adversarial-text-layout": "node scripts/test-adversarial-text-layout.mjs",
    "test:media-raster": "node scripts/test-media-raster.mjs",
    "test:dom-snapshot-media": "node scripts/test-dom-snapshot-media.mjs",
    "test:dom-snapshot-memory": "node scripts/test-dom-snapshot-memory.mjs",
    "test:obsidian-verifier": "node scripts/verify-obsidian-fixture-pdfs.mjs --self-test",
    "test:render-fidelity": "node scripts/test-render-fidelity.mjs",
    "test:render-fidelity-webkit": "node scripts/test-render-fidelity-webkit.mjs",
    "prepare:test-vault": "npm run build && node scripts/prepare-test-vault.mjs",
    "verify:test-vault-pdfs": "node scripts/verify-obsidian-fixture-pdfs.mjs",
    "test": "npm run typecheck && npm run build && npm run test:licenses && npm run test:text-layout && npm run test:adversarial-text-layout && npm run test:media-raster && npm run test:dom-snapshot-media && npm run test:dom-snapshot-memory && npm run test:obsidian-verifier && npm run test:korean-font",
    "test:ci": "npm test && npm run test:render-fidelity"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "pdf",
    "mobile"
  ],
  "author": "Murat / Korean font fork contributors",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.5",
    "obsidian": "^1.8.7",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "pako": "1.0.11",
    "pdf-lib": "1.17.1",
    "pdflib-fontkit": "1.8.11"
  }
}
